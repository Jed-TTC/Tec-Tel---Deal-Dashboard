# Copy this to .env and fill in your credentials

# HubSpot — create a Private App at app.hubspot.com → Settings → Integrations → Private Apps
# Required scopes: crm.objects.deals.read, crm.objects.contacts.read, crm.objects.notes.write, crm.objects.owners.read, crm.schemas.deals.read
HUBSPOT_API_KEY=

# Microsoft 365 — register an app at portal.azure.com → App registrations
# Required permissions: Mail.Read (delegated), offline_access
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=http://localhost:3001/api/auth/ms/callback

# Fellow.ai — get API key from fellow.app/app/account/api
FELLOW_API_KEY=

# Anthropic — get from console.anthropic.com
ANTHROPIC_API_KEY=

# Server
PORT=3001
# Comma-separated list of allowed frontend origins
# Local: http://localhost:3000
# Railway: https://your-app.up.railway.app
ALLOWED_ORIGINS=http://localhost:3000
